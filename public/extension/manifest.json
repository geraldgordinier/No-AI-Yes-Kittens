{
  "manifest_version": 3,
  "name": "No AI, Yes Kitten",
  "version": "1.0.0",
  "description": "Replaces AI-generated LinkedIn posts with pictures of kittens.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["kittens/*.jpg", "icons/*.png"],
      "matches": ["*://*.linkedin.com/*"]
    }
  ]
}
